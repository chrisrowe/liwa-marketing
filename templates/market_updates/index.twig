    <body>
    {% include "_includes/sections/masthead" with { 'signpost': sectionName } %}
    <main class="main">
        <section data-section="leadspace" class="leadspace">
            <div class="container">
                <div class="row">
                    <div class="col-12 col-md-9">
                        <hgroup>
                            <h1>Sign Up For Market Updates</h1>
                        </hgroup>
                    </div>
                </div>
            </div>
        </section>

        <div class="container">
            <div class="row">
                <div class="col-12 col-md-6 col-lg-4">
                    <form class="mt-0" id="form" method="post" action="market-updates.php">
                        <div class="my-5">
                            <div class="mb-3">
                                <label class="form-label">First name</label>
                                <input type="text" class="form-control" name="firstname" id="firstname" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Last name</label>
                                <input type="text" class="form-control" name="lastname" id="lastname" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email address</label>
                                <input type="email" class="form-control" name="email" id="email" required email>
                                <div class="form-text">We'll never share your email with anyone else.</div>
                            </div>
                            <button type="button" class="btn btn-primary g-recaptcha"
                                data-sitekey="6LfXOTgiAAAAAADBfnZo17f75b59ZWWkNjlIrHcc" 
                                data-callback='onSubmit' 
                                data-action='submit'>Submit</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
    {% include '_includes/sections/footer' %}

        {% include '_includes/document/scripts' %}
        <script src="https://code.jquery.com/jquery-3.6.1.min.js" integrity="sha256-o88AwQnZB+VDvE9tvIXrMQaPlFFSUTR+nldQm1LuPXQ=" crossorigin="anonymous"></script>
